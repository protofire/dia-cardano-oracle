    "ethers": "^6.15.0",
    "libsodium-wrappers-sumo": "0.8.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "libsodium-wrappers-sumo": "0.8.3",
    "libsodium-sumo": "0.8.3"
