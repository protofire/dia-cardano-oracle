{
  "name": "@diadata-org/dia-cardano-oracle-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript CLI for Preview and mainnet operations of the DIA Cardano Oracle project",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
